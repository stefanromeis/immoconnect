{
  "name": "immoconnect",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @immoconnect/web dev",
    "dev:api": "pnpm --filter @immoconnect/api dev",
    "build": "pnpm --filter @immoconnect/shared build && pnpm --filter @immoconnect/api build && pnpm --filter @immoconnect/web build",
    "start": "pnpm -r --parallel start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
